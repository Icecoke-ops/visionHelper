# 统一换行符为 LF（仓库内），Windows 检出时可自动转为 CRLF
* text=auto

# Shell 脚本统一 LF，避免 CRLF 破坏 shebang
*.sh text eol=lf

# Python 永远用 LF（避免 \r\n 被解释器识别为语法问题）
*.py text eol=lf

# 构建脚本 Windows 批处理保持 CRLF
*.bat text eol=crlf

# 二进制文件标记
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pt binary
*.onnx binary
